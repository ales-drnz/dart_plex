# Integration test configuration for dart_plex.
#
# Copy this file to `.env.test` (which is gitignored) and fill in
# the real values. Never commit `.env.test` itself.
#
# Plex Media Server requires a claim token tied to a Plex account
# to come online. Create a free, dedicated test account at
# <https://plex.tv/sign-up> — do NOT use your real Plex account.
# See README.md in this directory for the full rationale.

# ─── Authentication ────────────────────────────────────────────────
# Pick ONE of the two approaches. The bootstrap prefers
# username/password if both are set.
#
# A. Username + password (simplest):
#    PLEX_TEST_USERNAME is the auto-assigned plex.tv username (NOT
#    your email's local part — when you sign up, plex.tv issues a
#    short alias like "hafig1". You can see yours at the top right
#    of plex.tv after logging in).
PLEX_TEST_USERNAME=your-plex-username
PLEX_TEST_PASSWORD=your-plex-password
#
# B. Auth token (recommended for 2FA accounts):
#    Run `dart run test/integration/get_plex_token.dart` to obtain
#    one via the PIN flow. Paste the printed value below.
#    PLEX_TEST_TOKEN=...

# ─── Docker ────────────────────────────────────────────────────────

# Docker image tag for the Plex Media Server used in tests. Pin to a
# specific version so the suite stays deterministic across machines.
PLEX_IMAGE_TAG=1.43.2.10687-563d026ea

# Exposed port on the host. Pick something unused so the test stack
# can run alongside a "real" PMS on 32400.
PLEX_HOST_PORT=42400
